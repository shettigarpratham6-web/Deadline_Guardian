rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Task Validation
    function isValidTask(task) {
      return task.userId is string 
        && task.userId == request.auth.uid
        && task.title is string 
        && task.title.size() > 0 
        && task.title.size() <= 200;
    }

    // Planner Validation
    function isValidPlanner(planner) {
      return planner.userId is string 
        && planner.userId == request.auth.uid
        && planner.todayPath is string;
    }

    // Notification Validation
    function isValidNotification(notification) {
      return notification.userId is string
        && notification.userId == request.auth.uid
        && notification.title is string
        && notification.title.size() > 0;
    }

    // Rules for Tasks
    match /tasks/{taskId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(taskId) 
        && isValidTask(incoming())
        && incoming().createdAt is string;
        
      allow update: if isSignedIn() 
        && isValidId(taskId) 
        && isValidTask(incoming())
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt is string;
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Rules for Planners
    match /planners/{plannerId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(plannerId) 
        && isValidPlanner(incoming());
        
      allow update: if isSignedIn() 
        && isValidId(plannerId) 
        && isValidPlanner(incoming())
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId;
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Rules for Notifications
    match /notifications/{notificationId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(notificationId) 
        && isValidNotification(incoming());
        
      allow update: if isSignedIn() 
        && isValidId(notificationId) 
        && isValidNotification(incoming())
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId;
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Rules for Users
    match /users/{userId} {
      allow read, write: if isSignedIn() && userId == request.auth.uid;
    }
  }
}
